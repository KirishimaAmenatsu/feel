#!/usr/bin/env python3
"""feel v1.3.0 —— 记录当前感受的命令行工具。

用法：
    feel              交互式记录
    feel <描述>        直接记录
    feel list         显示最近 10 条日志
    feel list -n <N>  显示最近 N 条日志
    feel list -a      显示所有日志
    feel delete <ts>  删除指定 Unix 时间戳的记录
    feel delete last  删除最后一条记录
    feel version      显示版本信息
    feel help         显示帮助信息

别名：
    ls             → list
    ls -a          → list -a
    del, rm        → delete
    -h, --help     → help
    -v, --version  → version
"""

import os
import sys
from datetime import datetime

VERSION = "1.3.0"


