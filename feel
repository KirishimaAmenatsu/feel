def _t() -> dict:
    """根据 LANG 环境变量返回翻译字典。"""
    lang = os.environ.get("LANG", "")
    if lang.startswith("zh"):
        return _ZH
    return _EN


# ── 路径 ──────────────────────────────────────────────────────────────

def _xdg_data_home() -> str:
    """返回 XDG_DATA_HOME，未设置时 fallback 到 ~/.local/share。"""
    base = os.environ.get("XDG_DATA_HOME")
    if base:
        return base
    return os.path.join(os.path.expanduser("~"), ".local", "share")


LOG_DIR = os.path.join(_xdg_data_home(), "feel")
LOG_FILE = os.path.join(LOG_DIR, "log")


# ── 核心逻辑 ──────────────────────────────────────────────────────────

def _write_log(feeling: str, note: str | None = None) -> None:
    """写入日志行。"""
    now = datetime.now()
    unix_ts = int(now.timestamp())
    timestamp = now.strftime("%Y-%m-%d %H:%M")
    parts = [str(unix_ts), timestamp, feeling]
    if note:
        parts.append(f"({note})")
    log_line = " ".join(parts) + "\n"

    os.makedirs(LOG_DIR, exist_ok=True)

    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(log_line)

    tr = _t()
    print(f"{tr['recorded']}: {log_line.strip()}")


def _list_logs(count: int | None = 10) -> None:
    """显示最近 count 条日志。count 为 None 时显示所有。"""
    tr = _t()

    if not os.path.isfile(LOG_FILE):
        print(tr["list.empty"])
        return

    with open(LOG_FILE, "r", encoding="utf-8") as f:
        lines = f.readlines()

    if not lines:
        print(tr["list.empty"])
        return

    if count is None:
        recent = lines
    else:
        recent = lines[-count:]

    for i, line in enumerate(recent, start=len(lines) - len(recent) + 1):
        print(f"{i:>4}  {line.rstrip()}")


def _delete_log(ts_str: str) -> None:
    """根据 Unix 时间戳删除对应的日志条目。"""
    tr = _t()

    if not os.path.isfile(LOG_FILE):
        print(tr["list.empty"])
        return

    with open(LOG_FILE, "r", encoding="utf-8") as f:
        lines = f.readlines()

    matched_idx = None
    for i, line in enumerate(lines):
        parts = line.strip().split()
        if parts and parts[0] == ts_str:
            matched_idx = i
            break

    if matched_idx is None:
        print(tr["delete.not_found"].format(ts=ts_str))
        return

    print(tr["delete.confirm"])
    print(f"  {lines[matched_idx].rstrip()}")

    try:
        answer = _prompt("[y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if answer in ("y", "yes"):
        del lines[matched_idx]
        with open(LOG_FILE, "w", encoding="utf-8") as f:
            f.writelines(lines)
        print(tr["delete.deleted"])
    else:
        print(tr["delete.cancelled"])


def _delete_last() -> None:
    """删除最后一条日志条目。"""
    tr = _t()

    if not os.path.isfile(LOG_FILE):
        print(tr["delete.last_empty"])
        return

    with open(LOG_FILE, "r", encoding="utf-8") as f:
        lines = f.readlines()

    if not lines:
        print(tr["delete.last_empty"])
        return

    last_idx = len(lines) - 1
    print(tr["delete.confirm"])
    print(f"  {lines[last_idx].rstrip()}")

    try:
        answer = _prompt("[y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if answer in ("y", "yes"):
        del lines[last_idx]
        with open(LOG_FILE, "w", encoding="utf-8") as f:
            f.writelines(lines)
        print(tr["delete.deleted"])
    else:
        print(tr["delete.cancelled"])


def _prompt(prompt: str) -> str:
    """读取用户输入，绕过 readline 以避免 CJK 宽字符丢失问题。"""
    sys.stdout.write(prompt)
    sys.stdout.flush()
    try:
        raw = sys.stdin.buffer.readline()
    except KeyboardInterrupt:
        raise
    return raw.decode("utf-8", errors="replace").rstrip("\n\r")


def _interactive() -> None:
    """交互式 TUI 模式。"""
    tr = _t()
    try:
        feeling = _prompt(tr["interactive.prompt"]).strip()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(0)

    if not feeling:
        sys.exit(0)

    try:
        note = _prompt(tr["interactive.note"]).strip()
    except (EOFError, KeyboardInterrupt):
        print()
        note = ""

    _write_log(feeling, note if note else None)


def _show_help() -> None:
    """显示帮助信息。"""
    tr = _t()
    lang = os.environ.get("LANG", "")
    is_zh = lang.startswith("zh")
    help_cmd_desc = "显示帮助信息" if is_zh else "Show this help message"

    print(tr["help.title"])
    print()
    print(tr["help.commands"])
    print(tr["help.interactive"])
    print(tr["help.record"])
    print(tr["help.list"])
    print(tr["help.delete"])
    print(tr["help.delete_last"])
    print(tr["help.version"])
    print(f"  help, -h, --help     {help_cmd_desc}")
    print()
    print(tr["help.aliases"])
    print(tr["help.alias_list"])
    print(tr["help.alias_list_a"])
    print(tr["help.alias_list_n"])
    print(tr["help.alias_delete"])
    print(tr["help.alias_help"])
    print(tr["help.alias_version"])


def _resolve_aliases(argv: list[str]) -> list[str]:
    """解析别名，将短命令转换为标准命令。"""
    if len(argv) < 2:
        return argv

    cmd = argv[1]

    # help 别名
    if cmd in ("-h", "--help"):
        return [argv[0], "help"]

    # version 别名
    if cmd in ("-v", "--version"):
        return [argv[0], "version"]

    # list 别名
    if cmd == "ls":
        return [argv[0], "list"] + argv[2:]

    # delete 别名
    if cmd in ("del", "rm"):
        return [argv[0], "delete"] + argv[2:]

    return argv


def main() -> None:
    if len(sys.argv) < 2:
        _interactive()
        return

    argv = _resolve_aliases(sys.argv)

    if argv[1] == "help":
        _show_help()
        return

    if argv[1] == "version":
        print(f"feel v{VERSION}")
        return

    if argv[1] == "list":
        args = argv[2:]
        count = 10  # 默认值
        show_all = False

        i = 0
        while i < len(args):
            if args[i] in ("-a", "--all"):
                show_all = True
                i += 1
            elif args[i] == "-n":
                if i + 1 >= len(args):
                    tr = _t()
                    print(tr["list.usage"])
                    sys.exit(1)
                try:
                    count = int(args[i + 1])
                    if count <= 0:
                        raise ValueError
                except ValueError:
                    tr = _t()
                    print(tr["list.usage"])
                    sys.exit(1)
                i += 2
            else:
                tr = _t()
                print(tr["list.usage"])
                sys.exit(1)

        _list_logs(count=None if show_all else count)
        return

    if argv[1] == "delete":
        if len(argv) < 3:
            tr = _t()
            print(tr["delete.usage"])
            sys.exit(1)
        if argv[2] == "last":
            _delete_last()
        else:
            _delete_log(argv[2])
        return

    description = " ".join(argv[1:])
    _write_log(description)


if __name__ == "__main__":
    main()
